# ------------------------------------------------------------------
# Barre Core Coach — environment variables
# Copy this file to `.env` and fill in your keys. NEVER commit `.env`.
# ------------------------------------------------------------------

# LLM gateway. All chat/generation calls route through OpenRouter
# (OpenAI-compatible). One key, swappable models.
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Chat + eval model IDs served by the gateway (OpenRouter model slugs).
CHAT_MODEL=openai/gpt-4.1-mini
EVAL_MODEL=openai/gpt-4.1-mini

# Embeddings run directly on OpenAI (gateways don't proxy embeddings well).
OPENAI_API_KEY=sk-...
EMBED_MODEL=text-embedding-3-small

# Agentic web-search tool.
TAVILY_API_KEY=tvly-...

# Monitoring / observability (LangSmith). When these are set, LangChain
# automatically traces every agent run, tool call, and token — no code changes.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=barre-core-coach
